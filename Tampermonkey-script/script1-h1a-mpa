// ==UserScript==
// @name         MPA Initial Load Test Products Rendered
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  Mäter initial laddningstid för React-baserad MPA-produktsida
// @match        http://localhost:5173/mpa-products.html*
// @grant        none
// ==/UserScript==

(function () {
    "use strict";

    const ITERATIONS = 100;

    const COUNTER_KEY = "mpa_initial_counter";
    const DATA_KEY = "mpa_initial_data";
    const RUN_KEY = "mpa_initial_running";

    function downloadCSV(data) {
        const blob = new Blob([data], { type: "text/csv" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = "mpa-initial-load-products-rendered.csv";
        document.body.appendChild(a);
        a.click();
        a.remove();

        URL.revokeObjectURL(url);
    }

    function waitForProductsRendered(timeout = 8000) {
        return new Promise((resolve, reject) => {
            const start = performance.now();

            const interval = setInterval(() => {
                const cards = document.querySelectorAll(".product-card");
                const images = document.querySelectorAll(".product-card img");

                if (cards.length >= 50 && images.length >= 50) {
                    clearInterval(interval);
                    resolve(performance.now());
                }

                if (performance.now() - start > timeout) {
                    clearInterval(interval);
                    reject(new Error("Products did not render in time"));
                }
            }, 50);
        });
    }

    window.startMPAInitialTest = function () {
        localStorage.setItem(RUN_KEY, "true");
        localStorage.setItem(COUNTER_KEY, "0");
        localStorage.setItem(
            DATA_KEY,
            "Iteration,LoadEventEnd_ms,DOMContentLoaded_ms,ProductsRendered_ms\n"
        );

        location.href = "/mpa-products.html";
    };

    window.stopMPAInitialTest = function () {
        localStorage.removeItem(RUN_KEY);
        localStorage.removeItem(COUNTER_KEY);
        localStorage.removeItem(DATA_KEY);
        console.log("MPA initial load test stopped");
    };

    if (localStorage.getItem(RUN_KEY) !== "true") return;

    window.addEventListener("load", async () => {
        try {
            const nav = performance.getEntriesByType("navigation")[0];
            const renderedTime = await waitForProductsRendered();

            let counter = parseInt(localStorage.getItem(COUNTER_KEY) || "0", 10);
            let data =
                localStorage.getItem(DATA_KEY) ||
                "Iteration,LoadEventEnd_ms,DOMContentLoaded_ms,ProductsRendered_ms\n";

            counter++;

            data += `${counter},${nav.loadEventEnd.toFixed(2)},${nav.domContentLoadedEventEnd.toFixed(2)},${renderedTime.toFixed(2)}\n`;

            localStorage.setItem(COUNTER_KEY, String(counter));
            localStorage.setItem(DATA_KEY, data);

            console.log(`MPA initial ${counter}/${ITERATIONS}: rendered=${renderedTime.toFixed(2)} ms`);

            if (counter >= ITERATIONS) {
                downloadCSV(data);

                localStorage.removeItem(RUN_KEY);
                localStorage.removeItem(COUNTER_KEY);
                localStorage.removeItem(DATA_KEY);

                alert("MPA initial load-test klart");
            } else {
                setTimeout(() => location.reload(), 1500);
            }
        } catch (error) {
            console.error(error);
            alert(error.message);
        }
    });

    console.log("MPA initial products rendered script loaded. Kör startMPAInitialTest()");
})();