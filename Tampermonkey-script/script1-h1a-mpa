// ==UserScript==
// @name         MPA Initial Load Test
// @namespace    http://tampermonkey.net/
// @version      1.0
// @match        http://localhost/*/mpa/products.php*
// @grant        none
// ==/UserScript==

(function () {
    "use strict";

    console.log("MPA script loaded");

    const ITERATIONS = 20;
    const COUNTER_KEY = "mpa_counter";
    const DATA_KEY = "mpa_data";
    const RUN_KEY = "mpa_running";

    function downloadCSV(data) {
        const blob = new Blob([data], { type: "text/csv" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "mpa-initial-load.csv";
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
    }

    window.startMPAInitialTest = function () {
        localStorage.setItem(RUN_KEY, "true");
        localStorage.setItem(COUNTER_KEY, "0");
        localStorage.setItem(DATA_KEY, "Iteration,LoadEventEnd_ms,DOMContentLoaded_ms\n");
        location.reload();
    };

    if (localStorage.getItem(RUN_KEY) !== "true") return;

    window.addEventListener("load", () => {
        setTimeout(() => {
            const nav = performance.getEntriesByType("navigation")[0];
            if (!nav) return;

            let counter = parseInt(localStorage.getItem(COUNTER_KEY) || "0", 10);
            let data = localStorage.getItem(DATA_KEY) || "Iteration,LoadEventEnd_ms,DOMContentLoaded_ms\n";

            counter++;
            data += `${counter},${nav.loadEventEnd.toFixed(2)},${nav.domContentLoadedEventEnd.toFixed(2)}\n`;

            localStorage.setItem(COUNTER_KEY, String(counter));
            localStorage.setItem(DATA_KEY, data);

            console.log(`MPA test ${counter}/${ITERATIONS}: load=${nav.loadEventEnd.toFixed(2)} ms`);

            if (counter >= ITERATIONS) {
                downloadCSV(data);
                localStorage.removeItem(RUN_KEY);
                localStorage.removeItem(COUNTER_KEY);
                localStorage.removeItem(DATA_KEY);
                alert("MPA-test klart");
            } else {
                setTimeout(() => location.reload(), 1500);
            }
        }, 50);
    });
})();