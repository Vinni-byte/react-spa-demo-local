// ==UserScript==
// @name         MPA Initial Load Test Products Ready
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  Mäter initial laddningstid för React-baserad MPA-produktsida med products-ready-signal
// @match        http://localhost:5173/mpa-products.html*
// @grant        none
// @run-at       document-start
// ==/UserScript==

(function () {
    "use strict";

    const ITERATIONS = 100; 

    const COUNTER_KEY = "mpa_initial_counter";
    const DATA_KEY = "mpa_initial_data";
    const RUN_KEY = "mpa_initial_running";

    const CSV_HEADER =
        "Iteration,LoadEventEnd_ms,DOMContentLoaded_ms,ProductsReady_ms\n";

    function downloadCSV(data) {
        const blob = new Blob([data], { type: "text/csv" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = "mpa-initial-products-ready.csv";
        document.body.appendChild(a);
        a.click();
        a.remove();

        URL.revokeObjectURL(url);
    }

    function waitForNavigationTimingComplete(timeout = 5000) {
        return new Promise((resolve) => {
            const start = performance.now();

            const interval = setInterval(() => {
                const nav = performance.getEntriesByType("navigation")[0];

                if (nav && nav.loadEventEnd > 0) {
                    clearInterval(interval);
                    resolve(nav);
                }

                if (performance.now() - start > timeout) {
                    clearInterval(interval);
                    resolve(nav);
                }
            }, 25);
        });
    }

    function waitForProductsReady(timeout = 10000) {
        return new Promise((resolve, reject) => {
            if (typeof window.__productsReadyTime === "number") {
                resolve(window.__productsReadyTime);
                return;
            }

            const checkInterval = setInterval(() => {
                if (typeof window.__productsReadyTime === "number") {
                    clearInterval(checkInterval);
                    clearTimeout(timer);
                    resolve(window.__productsReadyTime);
                }
            }, 25);

            const timer = setTimeout(() => {
                clearInterval(checkInterval);
                reject(new Error("products-ready signal did not arrive in time"));
            }, timeout);

            window.addEventListener(
                "products-ready",
                (event) => {
                    clearInterval(checkInterval);
                    clearTimeout(timer);
                    resolve(event.detail.time);
                },
                { once: true }
            );
        });
    }

    window.startMPAInitialTest = function () {
        localStorage.setItem(RUN_KEY, "true");
        localStorage.setItem(COUNTER_KEY, "0");
        localStorage.setItem(DATA_KEY, CSV_HEADER);

        if (location.pathname === "/mpa-products.html") {
            location.reload();
        } else {
            location.href = "/mpa-products.html";
        }
    };

    window.stopMPAInitialTest = function () {
        localStorage.removeItem(RUN_KEY);
        localStorage.removeItem(COUNTER_KEY);
        localStorage.removeItem(DATA_KEY);
        console.log("MPA initial load test stopped");
    };

    async function runMeasurement() {
        if (localStorage.getItem(RUN_KEY) !== "true") return;

        try {
            const productsReadyPromise = waitForProductsReady();

            const nav = await waitForNavigationTimingComplete();
            const productsReadyTime = await productsReadyPromise;

            let counter = parseInt(localStorage.getItem(COUNTER_KEY) || "0", 10);
            let data = localStorage.getItem(DATA_KEY) || CSV_HEADER;

            counter++;

            data += `${counter},${nav.loadEventEnd.toFixed(2)},${nav.domContentLoadedEventEnd.toFixed(2)},${productsReadyTime.toFixed(2)}\n`;

            localStorage.setItem(COUNTER_KEY, String(counter));
            localStorage.setItem(DATA_KEY, data);

            console.log(
                `MPA initial ${counter}/${ITERATIONS}: productsReady=${productsReadyTime.toFixed(2)} ms`
            );

            if (counter >= ITERATIONS) {
                downloadCSV(data);

                localStorage.removeItem(RUN_KEY);
                localStorage.removeItem(COUNTER_KEY);
                localStorage.removeItem(DATA_KEY);

                alert("MPA initial load-test klart");
            } else {
                setTimeout(() => location.reload(), 1500);
            }
        } catch (error) {
            console.error(error);
            alert(error.message);
        }
    }

    runMeasurement();

    console.log("MPA initial products-ready script loaded. Kör startMPAInitialTest()");
})();