// ==UserScript==
// @name         SPA Flow Navigation Test Ready Signals
// @namespace    http://tampermonkey.net/
// @version      2.1
// @description  Mäter upprepad navigering i SPA med React ready-signaler
// @match        http://localhost:5173/*
// @grant        none
// @run-at       document-start
// ==/UserScript==

(function () {
    "use strict";

    const ITERATIONS = 100;

    const RUN_KEY = "spa_flow_running";
    const COUNTER_KEY = "spa_flow_counter";
    const DATA_KEY = "spa_flow_data";

    const CSV_HEADER =
        "Iteration,TotalFlowTime_ms,ProductsReady_ms,ProductReady_ms,CartReady_ms,CartCount,FirstProductId\n";

    const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

    function downloadCSV(csv) {
        const blob = new Blob([csv], { type: "text/csv" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = "spa-flow-navigation-ready-signals.csv";
        document.body.appendChild(a);
        a.click();
        a.remove();

        URL.revokeObjectURL(url);
    }

    function waitForReadySignal(signalName, globalTimeName, timeout = 10000) {
        return new Promise((resolve, reject) => {
            if (typeof window[globalTimeName] === "number") {
                resolve(window[globalTimeName]);
                return;
            }

            const checkInterval = setInterval(() => {
                if (typeof window[globalTimeName] === "number") {
                    clearInterval(checkInterval);
                    clearTimeout(timer);
                    resolve(window[globalTimeName]);
                }
            }, 25);

            const timer = setTimeout(() => {
                clearInterval(checkInterval);
                reject(new Error(`${signalName} signal did not arrive in time`));
            }, timeout);

            window.addEventListener(
                signalName,
                (event) => {
                    clearInterval(checkInterval);
                    clearTimeout(timer);
                    resolve(event.detail.time);
                },
                { once: true }
            );
        });
    }

    function waitForProductsReady() {
        return waitForReadySignal("products-ready", "__productsReadyTime");
    }

    function waitForProductReady() {
        return waitForReadySignal("product-ready", "__productReadyTime");
    }

    function waitForCartReady(timeout = 10000) {
        return new Promise((resolve, reject) => {
            if (typeof window.__cartReadyTime === "number") {
                const cart = JSON.parse(localStorage.getItem("cart") || "[]");

                resolve({
                    time: window.__cartReadyTime,
                    cartCount: cart.length,
                    firstProductId: cart[0]?.id ?? null
                });

                return;
            }

            const timer = setTimeout(() => {
                reject(new Error("cart-ready signal did not arrive in time"));
            }, timeout);

            window.addEventListener(
                "cart-ready",
                (event) => {
                    clearTimeout(timer);

                    resolve({
                        time: event.detail.time,
                        cartCount: event.detail.cartCount,
                        firstProductId: event.detail.firstProductId
                    });
                },
                { once: true }
            );
        });
    }

    async function waitForSelector(selector, timeout = 5000) {
        const start = performance.now();

        while (performance.now() - start < timeout) {
            const element = document.querySelector(selector);
            if (element) return element;
            await wait(25);
        }

        throw new Error("Kunde inte hitta element: " + selector);
    }

    async function waitForPath(pathStart, timeout = 5000) {
        const start = performance.now();

        while (performance.now() - start < timeout) {
            if (window.location.pathname.startsWith(pathStart)) return;
            await wait(25);
        }

        throw new Error("Nådde inte path: " + pathStart);
    }

    async function resetAppStateForNextIteration() {
        localStorage.removeItem("cart");

        window.__productsReadyTime = null;
        window.__productReadyTime = null;
        window.__cartReadyTime = null;

        window.dispatchEvent(new CustomEvent("measurement-reset-cart"));

        await wait(100);
    }

    function goHome() {
        window.location.href = "/";
    }

    async function runFlowOnce() {
        await resetAppStateForNextIteration();

        const productsLink = await waitForSelector('a[href="/products"]');

        window.__productsReadyTime = null;
        window.__productReadyTime = null;
        window.__cartReadyTime = null;

        const startTime = performance.now();

        productsLink.click();
        await waitForPath("/products");
        const productsReadyTime = await waitForProductsReady();

        window.__productReadyTime = null;

        const productLink = await waitForSelector(".product-card a");
        productLink.click();

        await waitForPath("/products/");
        const productReadyTime = await waitForProductReady();

        const addButton = await waitForSelector("#button-product");
        addButton.click();

        await wait(100);

        window.__cartReadyTime = null;

        const cartLink = await waitForSelector('a[href="/cart"]');
        cartLink.click();

        await waitForPath("/cart");
        const cartReadyResult = await waitForCartReady();

        const totalTime = cartReadyResult.time - startTime;

        return {
            totalTime,
            productsReadyTime: productsReadyTime - startTime,
            productReadyTime: productReadyTime - startTime,
            cartReadyTime: cartReadyResult.time - startTime,
            cartCount: cartReadyResult.cartCount,
            firstProductId: cartReadyResult.firstProductId
        };
    }

    window.startSPAFlowTest = function () {
        localStorage.setItem(RUN_KEY, "true");
        localStorage.setItem(COUNTER_KEY, "0");
        localStorage.setItem(DATA_KEY, CSV_HEADER);

        resetAppStateForNextIteration();

        console.log("Startar SPA flow-test med ready-signaler...");
        goHome();
    };

    window.stopSPAFlowTest = function () {
        localStorage.removeItem(RUN_KEY);
        localStorage.removeItem(COUNTER_KEY);
        localStorage.removeItem(DATA_KEY);

        resetAppStateForNextIteration();

        console.log("SPA flow-test stoppat");
    };

    async function continueTestIfRunning() {
        if (localStorage.getItem(RUN_KEY) !== "true") return;

        let counter = parseInt(localStorage.getItem(COUNTER_KEY) || "0", 10);
        let data = localStorage.getItem(DATA_KEY) || CSV_HEADER;

        if (counter >= ITERATIONS) {
            downloadCSV(data);

            localStorage.removeItem(RUN_KEY);
            localStorage.removeItem(COUNTER_KEY);
            localStorage.removeItem(DATA_KEY);

            await resetAppStateForNextIteration();

            alert("SPA flow-test klart");
            return;
        }

        if (window.location.pathname !== "/") {
            goHome();
            return;
        }

        try {
            await wait(300);

            const result = await runFlowOnce();

            counter++;

            data += `${counter},${result.totalTime.toFixed(2)},${result.productsReadyTime.toFixed(2)},${result.productReadyTime.toFixed(2)},${result.cartReadyTime.toFixed(2)},${result.cartCount},${result.firstProductId}\n`;

            localStorage.setItem(COUNTER_KEY, String(counter));
            localStorage.setItem(DATA_KEY, data);

            console.log(
                `SPA flow ${counter}/${ITERATIONS}: total=${result.totalTime.toFixed(2)} ms, cartCount=${result.cartCount}, productId=${result.firstProductId}`
            );

            setTimeout(() => {
                goHome();
            }, 700);
        } catch (error) {
            console.error("SPA flow-test stoppades:", error);
            alert("SPA flow-test stoppades: " + error.message);
        }
    }

    window.addEventListener("load", () => {
        setTimeout(continueTestIfRunning, 300);
    });

    console.log("SPA flow test ready-signals loaded. Kör startSPAFlowTest()");
})();