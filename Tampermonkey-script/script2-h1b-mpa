// ==UserScript==
// @name         MPA Flow Navigation Test Performance API
// @namespace    http://tampermonkey.net/
// @version      3.0
// @description  Mäter MPA-navigeringsflöde genom att summera faktiska sidladdningstider
// @match        http://localhost/*/mpa/*
// @grant        none
// ==/UserScript==

(function () {
    "use strict";

    const ITERATIONS = 20;

    const RUN_KEY = "mpa_perf_running";
    const COUNTER_KEY = "mpa_perf_counter";
    const DATA_KEY = "mpa_perf_data";
    const STEP_KEY = "mpa_perf_step";
    const FLOW_SUM_KEY = "mpa_perf_flow_sum";

    const BASE =
        window.location.origin +
        window.location.pathname.split("/mpa/")[0] +
        "/mpa/";

    function goTo(page) {
        window.location.href = BASE + page;
    }

    function getLoadTime() {
        const nav = performance.getEntriesByType("navigation")[0];
        if (!nav) return 0;
        return nav.loadEventEnd;
    }

    function downloadCSV(csv) {
        const blob = new Blob([csv], { type: "text/csv" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = "mpa-flow-performance.csv";
        document.body.appendChild(a);
        a.click();
        a.remove();

        URL.revokeObjectURL(url);
    }

    async function clearCartSilent() {
        await fetch(BASE + "clearcart.php?silent=1", {
            method: "GET",
            credentials: "include"
        });
    }

    function addCurrentPageLoadTime() {
        const currentSum = parseFloat(localStorage.getItem(FLOW_SUM_KEY) || "0");
        const loadTime = getLoadTime();
        const newSum = currentSum + loadTime;

        localStorage.setItem(FLOW_SUM_KEY, String(newSum));

        console.log("Page load:", loadTime.toFixed(2), "ms");
        console.log("Flow sum:", newSum.toFixed(2), "ms");
    }

    async function saveResult() {
        let counter = parseInt(localStorage.getItem(COUNTER_KEY) || "0", 10);
        let data =
            localStorage.getItem(DATA_KEY) ||
            "Iteration,TotalPageLoadTime_ms\n";

        const totalTime = parseFloat(localStorage.getItem(FLOW_SUM_KEY) || "0");

        counter++;
        data += `${counter},${totalTime.toFixed(2)}\n`;

        localStorage.setItem(COUNTER_KEY, String(counter));
        localStorage.setItem(DATA_KEY, data);

        console.log(`MPA flow ${counter}/${ITERATIONS}: ${totalTime.toFixed(2)} ms`);

        if (counter >= ITERATIONS) {
            downloadCSV(data);

            localStorage.removeItem(RUN_KEY);
            localStorage.removeItem(COUNTER_KEY);
            localStorage.removeItem(DATA_KEY);
            localStorage.removeItem(STEP_KEY);
            localStorage.removeItem(FLOW_SUM_KEY);

            alert("MPA flow performance-test klart");
        } else {
            localStorage.setItem(STEP_KEY, "home");
            localStorage.setItem(FLOW_SUM_KEY, "0");

            await clearCartSilent();

            setTimeout(() => {
                goTo("index.php");
            }, 1200);
        }
    }

    window.startMPAFlowTest = async function () {
        localStorage.setItem(RUN_KEY, "true");
        localStorage.setItem(COUNTER_KEY, "0");
        localStorage.setItem(DATA_KEY, "Iteration,TotalPageLoadTime_ms\n");
        localStorage.setItem(STEP_KEY, "home");
        localStorage.setItem(FLOW_SUM_KEY, "0");

        await clearCartSilent();

        console.log("Startar MPA Performance API flow-test...");
        goTo("index.php");
    };

    window.stopMPAFlowTest = async function () {
        localStorage.removeItem(RUN_KEY);
        localStorage.removeItem(COUNTER_KEY);
        localStorage.removeItem(DATA_KEY);
        localStorage.removeItem(STEP_KEY);
        localStorage.removeItem(FLOW_SUM_KEY);

        await clearCartSilent();

        console.log("MPA-test stoppat och rensat.");
    };

    window.addEventListener("load", () => {
        if (localStorage.getItem(RUN_KEY) !== "true") return;

        setTimeout(async () => {
            const step = localStorage.getItem(STEP_KEY);
            const path = window.location.pathname;

            console.log("-----");
            console.log("STEP:", step);
            console.log("PATH:", path);
            console.log("COUNTER:", localStorage.getItem(COUNTER_KEY));

            if (step === "home" && path.includes("index.php")) {
                addCurrentPageLoadTime();

                localStorage.setItem(STEP_KEY, "products");

                setTimeout(() => {
                    goTo("products.php");
                }, 1100);

                return;
            }

            if (step === "products" && path.includes("products.php")) {
                addCurrentPageLoadTime();

                const productLink = document.querySelector(".product-card a");

                if (!productLink) {
                    alert("Kunde inte hitta produktlänk på products.php");
                    return;
                }

                localStorage.setItem(STEP_KEY, "product");

                setTimeout(() => {
                    window.location.href = productLink.href;
                }, 1100);

                return;
            }

            if (step === "product" && path.includes("product.php")) {
                addCurrentPageLoadTime();

                localStorage.setItem(STEP_KEY, "cart");

                await fetch(window.location.href, {
                    method: "POST",
                    credentials: "include"
                });

                setTimeout(() => {
                    goTo("cart.php");
                }, 1100);

                return;
            }

            if (step === "cart" && path.includes("cart.php")) {
                addCurrentPageLoadTime();

                await saveResult();

                return;
            }

            console.warn("Ingen matchande step/path:", step, path);
        }, 1200);
    });

    console.log("MPA Performance API flow-test loaded. Kör startMPAFlowTest()");
})();