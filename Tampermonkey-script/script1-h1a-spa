// ==UserScript==
// @name         SPA Initial Load Test Products Ready
// @namespace    http://tampermonkey.net/
// @version      3.1
// @description  Mäter initial laddningstid för SPA produktsida med products-ready-signal från React
// @match        http://localhost:5173/products*
// @grant        none
// @run-at       document-start
// ==/UserScript==

(function () {
    "use strict";

    const ITERATIONS = 20;

    const COUNTER_KEY = "spa_initial_counter";
    const DATA_KEY = "spa_initial_data";
    const RUN_KEY = "spa_initial_running";

    const CSV_HEADER =
        "Iteration,LoadEventEnd_ms,DOMContentLoaded_ms,ProductsReady_ms\n";

    function downloadCSV(data) {
        const blob = new Blob([data], { type: "text/csv" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = "spa-initial-products-ready.csv";
        document.body.appendChild(a);
        a.click();
        a.remove();

        URL.revokeObjectURL(url);
    }

    function waitForPageLoad() {
        return new Promise((resolve) => {
            if (document.readyState === "complete") {
                resolve();
            } else {
                window.addEventListener("load", resolve, { once: true });
            }
        });
    }

    function waitForProductsReady(timeout = 10000) {
        return new Promise((resolve, reject) => {
            if (typeof window.__productsReadyTime === "number") {
                resolve(window.__productsReadyTime);
                return;
            }

            const checkInterval = setInterval(() => {
                if (typeof window.__productsReadyTime === "number") {
                    clearInterval(checkInterval);
                    clearTimeout(timer);
                    resolve(window.__productsReadyTime);
                }
            }, 25);

            const timer = setTimeout(() => {
                clearInterval(checkInterval);
                reject(new Error("products-ready signal did not arrive in time"));
            }, timeout);

            window.addEventListener(
                "products-ready",
                (event) => {
                    clearInterval(checkInterval);
                    clearTimeout(timer);
                    resolve(event.detail.time);
                },
                { once: true }
            );
        });
    }

    window.startSPAInitialTest = function () {
        localStorage.setItem(RUN_KEY, "true");
        localStorage.setItem(COUNTER_KEY, "0");
        localStorage.setItem(DATA_KEY, CSV_HEADER);

        if (location.pathname === "/products") {
            location.reload();
        } else {
            location.href = "/products";
        }
    };

    window.stopSPAInitialTest = function () {
        localStorage.removeItem(RUN_KEY);
        localStorage.removeItem(COUNTER_KEY);
        localStorage.removeItem(DATA_KEY);
        console.log("SPA initial load test stopped");
    };

    async function runMeasurement() {
        if (localStorage.getItem(RUN_KEY) !== "true") return;

        try {
            const productsReadyPromise = waitForProductsReady();

            await waitForPageLoad();

            const productsReadyTime = await productsReadyPromise;
            const nav = performance.getEntriesByType("navigation")[0];

            let counter = parseInt(localStorage.getItem(COUNTER_KEY) || "0", 10);
            let data = localStorage.getItem(DATA_KEY) || CSV_HEADER;

            counter++;

            data += `${counter},${nav.loadEventEnd.toFixed(2)},${nav.domContentLoadedEventEnd.toFixed(2)},${productsReadyTime.toFixed(2)}\n`;

            localStorage.setItem(COUNTER_KEY, String(counter));
            localStorage.setItem(DATA_KEY, data);

            console.log(
                `SPA initial ${counter}/${ITERATIONS}: productsReady=${productsReadyTime.toFixed(2)} ms`
            );

            if (counter >= ITERATIONS) {
                downloadCSV(data);

                localStorage.removeItem(RUN_KEY);
                localStorage.removeItem(COUNTER_KEY);
                localStorage.removeItem(DATA_KEY);

                alert("SPA initial load-test klart");
            } else {
                setTimeout(() => location.reload(), 1500);
            }
        } catch (error) {
            console.error(error);
            alert(error.message);
        }
    }

    runMeasurement();

    console.log("SPA initial products-ready script loaded. Kör startSPAInitialTest()");
})();